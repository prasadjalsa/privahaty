rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isRoomMember(roomId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    match /rooms/{roomId} {
      allow read: if isRoomMember(roomId);

      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['expiryMinutes', 'createdAt'])
                    && request.resource.data.expiryMinutes in [10, 30, 60]
                    && request.resource.data.createdAt == request.time;

      // No client updates needed — room doc is immutable after creation
      allow update: if false;
      allow delete: if false;

      match /_secret/hash {
        allow create: if request.auth != null
                      && request.resource.data.keys().hasOnly(['secretHash'])
                      && request.resource.data.secretHash is string
                      && request.resource.data.secretHash.size() == 64
                      && !exists(/databases/$(database)/documents/rooms/$(roomId)/_secret/hash);
        allow read, update, delete: if false;
      }

      match /members/{uid} {
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.keys().hasOnly(['nickname', 'joinedAt', 'secretHash'])
                      && request.resource.data.nickname is string
                      && request.resource.data.nickname.size() > 0
                      && request.resource.data.nickname.size() <= 32
                      && request.resource.data.joinedAt == request.time
                      && request.resource.data.secretHash is string
                      && get(/databases/$(database)/documents/rooms/$(roomId)/_secret/hash).data.secretHash
                         == request.resource.data.secretHash;

        allow read: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if false;
      }

      match /messages/{msgId} {
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId)
                      && request.resource.data.keys().hasOnly(['text', 'nickname', 'createdAt', 'expiresAt'])
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000
                      && request.resource.data.createdAt == request.time
                      && request.resource.data.expiresAt is timestamp
                      && request.resource.data.expiresAt > request.time
                      && request.resource.data.nickname
                         == get(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid)).data.nickname;

        allow delete: if isRoomMember(roomId);
        allow update: if false;
      }
    }
  }
}
